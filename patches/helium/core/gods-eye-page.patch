+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+'use strict';
+
+const TIME_API_URL = 'https://timeapi.io/api/time/current/zone?timeZone=UTC';
+
+let state = {
+  domains: [],
+  keywords: [],
+  expiryTimestamp: 0,
+  active: false,
+  currentUtcSeconds: 0,
+};
+
+// Fetch current UTC time from TimeAPI
+async function fetchUtcTime() {
+  try {
+    const resp = await fetch(TIME_API_URL);
+    const data = await resp.json();
+    // Parse dateTime string to Unix timestamp
+    const dt = new Date(data.dateTime + 'Z');
+    return Math.floor(dt.getTime() / 1000);
+  } catch (e) {
+    // Fallback: use local Date (less tamper-resistant but functional)
+    return Math.floor(Date.now() / 1000);
+  }
+}
+
+function formatDate(unixSeconds) {
+  if (!unixSeconds) return '';
+  const d = new Date(unixSeconds * 1000);
+  return d.toLocaleString();
+}
+
+function daysUntil(unixSeconds, nowSeconds) {
+  const diff = unixSeconds - nowSeconds;
+  if (diff <= 0) return 0;
+  return Math.ceil(diff / 86400);
+}
+
+function renderDomains() {
+  const list = document.getElementById('domains-list');
+  list.innerHTML = '';
+  if (state.domains.length === 0) {
+    list.innerHTML = '<span class="empty-hint">No domains added yet</span>';
+    return;
+  }
+  state.domains.forEach((d, i) => {
+    const tag = document.createElement('span');
+    tag.className = 'tag' + (state.active ? ' locked' : '');
+    const btn = document.createElement('button');
+    btn.className = 'btn-remove';
+    btn.textContent = '×';
+    btn.disabled = state.active;
+    btn.title = state.active ? 'Locked until expiry' : 'Remove';
+    btn.onclick = () => removeDomain(d);
+    tag.textContent = d;
+    tag.appendChild(btn);
+    list.appendChild(tag);
+  });
+}
+
+function renderKeywords() {
+  const list = document.getElementById('keywords-list');
+  list.innerHTML = '';
+  if (state.keywords.length === 0) {
+    list.innerHTML = '<span class="empty-hint">No keywords added yet</span>';
+    return;
+  }
+  state.keywords.forEach((k) => {
+    const tag = document.createElement('span');
+    tag.className = 'tag' + (state.active ? ' locked' : '');
+    const btn = document.createElement('button');
+    btn.className = 'btn-remove';
+    btn.textContent = '×';
+    btn.disabled = state.active;
+    btn.title = state.active ? 'Locked until expiry' : 'Remove';
+    btn.onclick = () => removeKeyword(k);
+    tag.textContent = k;
+    tag.appendChild(btn);
+    list.appendChild(tag);
+  });
+}
+
+function renderStatus() {
+  const bar = document.getElementById('status-bar');
+  const text = document.getElementById('status-text');
+  const expiryInput = document.getElementById('expiry-input');
+  const saveBtn = document.getElementById('save-btn');
+  const expiryDisplay = document.getElementById('expiry-display');
+
+  if (state.active && state.expiryTimestamp > state.currentUtcSeconds) {
+    bar.className = 'status-bar active';
+    const days = daysUntil(state.expiryTimestamp, state.currentUtcSeconds);
+    text.textContent = `🔒 Restrictions active — ${days} day${days !== 1 ? 's' : ''} remaining (until ${formatDate(state.expiryTimestamp)})`;
+    expiryInput.disabled = true;
+    saveBtn.textContent = '🔒 Locked — Add new entries above';
+    saveBtn.disabled = true;
+    expiryDisplay.style.display = 'flex';
+    expiryDisplay.textContent = `Unlocks: ${formatDate(state.expiryTimestamp)}`;
+  } else {
+    if (state.active && state.expiryTimestamp <= state.currentUtcSeconds) {
+      // Expired — deactivate
+      state.active = false;
+      state.expiryTimestamp = 0;
+    }
+    bar.className = 'status-bar inactive';
+    text.textContent = 'No active restrictions — configure below and lock';
+    expiryInput.disabled = false;
+    saveBtn.textContent = '🔒 Save & Lock';
+    saveBtn.disabled = false;
+    expiryDisplay.style.display = 'none';
+  }
+}
+
+async function init() {
+  // Fetch UTC time first
+  const utcNow = await fetchUtcTime();
+  state.currentUtcSeconds = utcNow;
+
+  document.getElementById('utc-time-display').textContent =
+    `Current UTC time: ${formatDate(utcNow)}`;
+
+  // Load data from C++ prefs via chrome.send
+  const data = await new Promise((resolve) => {
+    cr.sendWithPromise('getGodsEyeData').then(resolve);
+  });

+  state.domains = (data.domains || []);
+  state.keywords = (data.keywords || []);
+  state.expiryTimestamp = data.expiryTimestamp || 0;
+  state.active = data.active || false;
+
+  // Re-check expiry with authoritative UTC time
+  if (state.active && state.expiryTimestamp > 0 &&
+      utcNow >= state.expiryTimestamp) {
+    state.active = false;
+    state.expiryTimestamp = 0;
+  }
+
+  renderDomains();
+  renderKeywords();
+  renderStatus();
+}
+
+function addDomain() {
+  const input = document.getElementById('domain-input');
+  const val = input.value.trim().toLowerCase().replace(/^https?:\/\//, '').replace(/\/$/, '');
+  if (!val) return;
+
+  if (state.active) {
+    // Active lock — send directly to C++ (always allowed)
+    cr.sendWithPromise('addDomain', val).then((ok) => {
+      if (ok) { state.domains.push(val); renderDomains(); }
+    });
+  } else {
+    if (!state.domains.includes(val)) state.domains.push(val);
+    renderDomains();
+  }
+  input.value = '';
+}
+
+function addKeyword() {
+  const input = document.getElementById('keyword-input');
+  const val = input.value.trim().toLowerCase();
+  if (!val) return;

+  if (state.active) {
+    cr.sendWithPromise('addKeyword', val).then((ok) => {
+      if (ok) { state.keywords.push(val); renderKeywords(); }
+    });
+  } else {
+    if (!state.keywords.includes(val)) state.keywords.push(val);
+    renderKeywords();
+  }
+  input.value = '';
+}
+
+function removeDomain(domain) {
+  if (state.active) return; // locked
+  state.domains = state.domains.filter(d => d !== domain);
+  renderDomains();
+}
+
+function removeKeyword(keyword) {
+  if (state.active) return; // locked
+  state.keywords = state.keywords.filter(k => k !== keyword);
+  renderKeywords();
+}
+
+async function saveData() {
+  if (state.active) return;
+  const errEl = document.getElementById('save-error');
+  errEl.style.display = 'none';

+  const expiryInput = document.getElementById('expiry-input');
+  if (!expiryInput.value) {
+    errEl.textContent = 'Please set an expiry date and time.';
+    errEl.style.display = 'block';
+    return;
+  }

+  // Convert local datetime to UTC unix timestamp via TimeAPI-fetched now
+  const localDt = new Date(expiryInput.value);
+  const expiryTs = Math.floor(localDt.getTime() / 1000);

+  if (expiryTs <= state.currentUtcSeconds) {
+    errEl.textContent = 'Expiry must be in the future.';
+    errEl.style.display = 'block';
+    return;
+  }

+  const ok = await cr.sendWithPromise(
+    'saveGodsEyeData',
+    state.domains,
+    state.keywords,
+    expiryTs
+  );

+  if (ok) {
+    state.expiryTimestamp = expiryTs;
+    state.active = true;
+    renderDomains();
+    renderKeywords();
+    renderStatus();
+  } else {
+    errEl.textContent = 'Failed to save. Please try again.';
+    errEl.style.display = 'block';
+  }
+}
+
+// Enter key support
+document.addEventListener('DOMContentLoaded', () => {
+  document.getElementById('domain-input').addEventListener('keydown', e => {
+    if (e.key === 'Enter') addDomain();
+  });
+  document.getElementById('keyword-input').addEventListener('keydown', e => {
+    if (e.key === 'Enter') addKeyword();
+  });
+  init();
+});
