+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/gods_eye/gods_eye_handler.h"
+
+#include "base/functional/bind.h"
+#include "base/time/time.h"
+#include "base/values.h"
+#include "chrome/browser/profiles/profile.h"
+#include "components/helium_services/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "components/prefs/scoped_user_pref_update.h"
+#include "content/public/browser/web_ui.h"
+
+GodsEyeHandler::GodsEyeHandler(content::BrowserContext* browser_context)
+    : browser_context_(browser_context),
+      pref_service_(
+          Profile::FromBrowserContext(browser_context)->GetPrefs()) {}
+
+GodsEyeHandler::~GodsEyeHandler() = default;
+
+void GodsEyeHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getGodsEyeData",
+      base::BindRepeating(&GodsEyeHandler::HandleGetGodsEyeData,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "saveGodsEyeData",
+      base::BindRepeating(&GodsEyeHandler::HandleSaveGodsEyeData,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "addDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleAddDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "addKeyword",
+      base::BindRepeating(&GodsEyeHandler::HandleAddKeyword,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeDomain",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveDomain,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "removeKeyword",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveKeyword,
+                          base::Unretained(this)));
+}
+
+void GodsEyeHandler::HandleGetGodsEyeData(const base::Value::List& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  const base::Value::List& domains =
+      pref_service_->GetList(prefs::kGodsEyeBlockedDomains);
+  const base::Value::List& keywords =
+      pref_service_->GetList(prefs::kGodsEyeBlockedKeywords);
+  double expiry = pref_service_->GetDouble(prefs::kGodsEyeExpiryTimestamp);
+  bool active = pref_service_->GetBoolean(prefs::kGodsEyeActive);
+
+  // Check if expiry has passed using system clock as a safety backstop.
+  // The UI also validates via TimeAPI, but we clear the active flag here
+  // if system time clearly shows expiry has passed.
+  if (active && expiry > 0.0) {
+    double now = base::Time::Now().InSecondsFSinceUnixEpoch();
+    if (now >= expiry) {
+      pref_service_->SetBoolean(prefs::kGodsEyeActive, false);
+      active = false;
+    }
+  }
+
+  base::Value::Dict result;
+  result.Set("domains", domains.Clone());
+  result.Set("keywords", keywords.Clone());
+  result.Set("expiryTimestamp", expiry);
+  result.Set("active", active);
+
+  ResolveJavascriptCallback(base::Value(callback_id),
+                             base::Value(std::move(result)));
+}
+
+void GodsEyeHandler::HandleSaveGodsEyeData(const base::Value::List& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  if (args.size() < 4) {
+    ResolveJavascriptCallback(base::Value(callback_id),
+                               base::Value(false));
+    return;
+  }
+
+  // args[1] = domains list, args[2] = keywords list, args[3] = expiryTimestamp
+  const base::Value::List* domains = args[1].GetIfList();
+  const base::Value::List* keywords = args[2].GetIfList();
+  double expiry = args[3].GetDouble();
+
+  if (!domains || !keywords || expiry <= 0.0) {
+    ResolveJavascriptCallback(base::Value(callback_id),
+                               base::Value(false));
+    return;
+  }
+
+  pref_service_->SetList(prefs::kGodsEyeBlockedDomains, domains->Clone());
+  pref_service_->SetList(prefs::kGodsEyeBlockedKeywords, keywords->Clone());
+  pref_service_->SetDouble(prefs::kGodsEyeExpiryTimestamp, expiry);
+  pref_service_->SetBoolean(prefs::kGodsEyeActive, true);
+
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddDomain(const base::Value::List& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  if (args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  const std::string& domain = args[1].GetString();
+  if (domain.empty()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  ScopedListPrefUpdate update(pref_service_, prefs::kGodsEyeBlockedDomains);
+  // Avoid duplicates
+  for (const auto& entry : *update) {
+    if (entry.is_string() && entry.GetString() == domain) {
+      ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+      return;
+    }
+  }
+  update->Append(domain);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddKeyword(const base::Value::List& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  if (args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  const std::string& keyword = args[1].GetString();
+  if (keyword.empty()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+
+  ScopedListPrefUpdate update(pref_service_, prefs::kGodsEyeBlockedKeywords);
+  for (const auto& entry : *update) {
+    if (entry.is_string() && entry.GetString() == keyword) {
+      ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+      return;
+    }
+  }
+  update->Append(keyword);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveDomain(const base::Value::List& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  if (args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  ScopedListPrefUpdate update(pref_service_, prefs::kGodsEyeBlockedDomains);
+  update->EraseValue(base::Value(args[1].GetString()));
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveKeyword(const base::Value::List& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  if (args.size() < 2 || !args[1].is_string()) {
+    ResolveJavascriptCallback(base::Value(callback_id), base::Value(false));
+    return;
+  }
+  ScopedListPrefUpdate update(pref_service_, prefs::kGodsEyeBlockedKeywords);
+  update->EraseValue(base::Value(args[1].GetString()));
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
