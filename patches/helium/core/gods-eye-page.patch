+    <div class="tag-list" id="domains-list"></div>
+    <div class="row">
+      <input type="text" id="domain-input" placeholder="e.g. example.com or sub.example.com" />
+      <button class="btn-add" id="domain-add-btn" onclick="addDomain()">Add</button>
+    </div>
+    <div class="time-note" style="margin-top:8px">
+      Adding new entries is always allowed. Deleting existing entries is locked until expiry.
+    </div>
+  </div>
+
+  <!-- Keywords Section -->
+  <div class="card">
+    <div class="card-title">🔍 Blocked Keywords</div>
+    <div class="tag-list" id="keywords-list"></div>
+    <div class="row">
+      <input type="text" id="keyword-input" placeholder="e.g. social media, news" />
+      <button class="btn-add" id="keyword-add-btn" onclick="addKeyword()">Add</button>
+    </div>
+    <div class="time-note" style="margin-top:8px">
+      If any blocked keyword appears in a URL or search query, the page will be blocked.
+    </div>
+  </div>
+
+  <div id="save-error"></div>
+  <button class="btn-save" id="save-btn" onclick="saveData()">🔒 Save &amp; Lock</button>
