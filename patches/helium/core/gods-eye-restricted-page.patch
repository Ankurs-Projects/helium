+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/gods_eye/restricted_page_ui.h"
+
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "ui/webui/webui_util.h"
+#include "components/grit/components_resources.h"
+
+HeliumRestrictedPage::HeliumRestrictedPage(content::WebUI* web_ui)
+    : WebUIController(web_ui) {
+  content::BrowserContext* browser_context =
+      web_ui->GetWebContents()->GetBrowserContext();
+  Profile* profile = Profile::FromBrowserContext(browser_context);
+  content::WebUIDataSource* source =
+      content::WebUIDataSource::CreateAndAdd(
+          profile, chrome::kHeliumRestrictedPageHost);
+
+  source->SetDefaultResource(IDR_HELIUM_RESTRICTED_PAGE_HTML);
+  source->DisableTrustedTypesCSP();
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src 'self' 'unsafe-inline';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ConnectSrc,
+      "connect-src 'self' https://timeapi.io;");
+}
+
+HeliumRestrictedPage::~HeliumRestrictedPage() = default;
--- /dev/null
+++ b/chrome/browser/resources/restricted_page/index.html
@@ -0,0 +1,230 @@
+<!DOCTYPE html>
+<html lang="en">
+<head>
+  <meta charset="UTF-8">
+  <meta name="viewport" content="width=device-width, initial-scale=1.0">
+  <title>Restricted — God's Eye</title>
+  <style>
+    :root {
+      --helium-blue: #3450d1;
+      --helium-blue-light: #e8ecfb;
+      --bg: #f5f5f5;
+      --surface: #ffffff;
+      --text: #1a1a1a;
+      --text-muted: #666;
+      --border: #e0e0e0;
+      --radius: 12px;
+    }
+    @media (prefers-color-scheme: dark) {
+      :root {
+        --bg: #1a1a1a;
+        --surface: #242424;
+        --text: #f0f0f0;
+        --text-muted: #aaa;
+        --border: #333;
+        --helium-blue-light: #1e2a5c;
+      }
+    }
+    * { box-sizing: border-box; margin: 0; padding: 0; }
+    body {
+      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
+      background: var(--bg);
+      color: var(--text);
+      min-height: 100vh;
+      display: flex;
+      align-items: center;
+      justify-content: center;
+      padding: 24px;
+    }
+    .card {
+      background: var(--surface);
+      border: 1px solid var(--border);
+      border-radius: var(--radius);
+      padding: 40px 36px;
+      max-width: 520px;
+      width: 100%;
+      text-align: center;
+    }
+    .eye-icon { font-size: 56px; margin-bottom: 16px; display: block; }
+    .title {
+      font-size: 22px;
+      font-weight: 700;
+      color: var(--helium-blue);
+      margin-bottom: 8px;
+    }
+    .blocked-detail {
+      background: var(--helium-blue-light);
+      border-radius: 8px;
+      padding: 12px 16px;
+      margin: 18px 0;
+      font-size: 14px;
+      color: var(--helium-blue);
+      word-break: break-all;
+    }
+    .blocked-label { font-weight: 600; margin-bottom: 4px; }
+    .blocked-value { font-family: monospace; font-size: 15px; }
+    .divider {
+      border: none;
+      border-top: 1px solid var(--border);
+      margin: 24px 0;
+    }
+    .quote-label {
+      font-size: 11px;
+      text-transform: uppercase;
+      letter-spacing: 0.08em;
+      color: var(--text-muted);
+      margin-bottom: 10px;
+    }
+    .quote {
+      font-size: 16px;
+      font-style: italic;
+      color: var(--text);
+      line-height: 1.6;
+      margin-bottom: 20px;
+    }
+    .countdown {
+      font-size: 13px;
+      color: var(--text-muted);
+      margin-top: 16px;
+    }
+    .countdown strong { color: var(--helium-blue); font-size: 15px; }
+    .btn-godseye {
+      display: inline-block;
+      margin-top: 20px;
+      padding: 10px 22px;
+      background: var(--helium-blue);
+      color: white;
+      border-radius: 8px;
+      border: none;
+      font-size: 14px;
+      cursor: pointer;
+      font-weight: 500;
+      text-decoration: none;
+    }
+    .btn-godseye:hover { opacity: 0.88; }
+  </style>
+</head>
+<body>
+<div class="card">
+  <span class="eye-icon">👁</span>
+  <div class="title">God's Eye — Access Restricted</div>

+  <div class="blocked-detail" id="blocked-detail">
+    <div class="blocked-label" id="blocked-label">Restricted</div>
+    <div class="blocked-value" id="blocked-value">—</div>
+  </div>

+  <hr class="divider">

+  <div class="quote-label">Motivation</div>
+  <div class="quote" id="quote-text"></div>

+  <div class="countdown" id="countdown">Loading expiry info…</div>

+  <a href="chrome://godseye" class="btn-godseye">Open God's Eye Settings</a>
+</div>

+<script>
+(function() {
+  'use strict';

+  const QUOTES = [
+    "The secret of getting ahead is getting started.",
+    "It always seems impossible until it's done. — Nelson Mandela",
+    "Focus on being productive instead of busy. — Tim Ferriss",
+    "You don't have to be great to start, but you have to start to be great.",
+    "The successful warrior is the average man, with laser-like focus. — Bruce Lee",
+    "One day or day one. You decide.",
+    "Your future is created by what you do today, not tomorrow.",
+    "Discipline is choosing between what you want now and what you want most.",
+    "Small daily improvements are the key to staggering long-term results.",
+    "Don't watch the clock; do what it does. Keep going. — Sam Levenson"
+  ];

+  const TIME_API = 'https://timeapi.io/api/time/current/zone?timeZone=UTC';

+  // Show a random quote
+  document.getElementById('quote-text').textContent =
+    QUOTES[Math.floor(Math.random() * QUOTES.length)];

+  // Parse query params
+  const params = new URLSearchParams(window.location.search);
+  const reason = params.get('reason') || 'domain';
+  const value = params.get('value') || '';
+  const expiry = parseFloat(params.get('expiry') || '0');

+  if (reason === 'keyword') {
+    document.getElementById('blocked-label').textContent =
+      'Restricted keyword detected:';
+  } else {
+    document.getElementById('blocked-label').textContent =
+      'Restricted domain detected:';
+  }
+  document.getElementById('blocked-value').textContent = value || '(unknown)';

+  // Fetch UTC time and compute days remaining
+  async function updateCountdown() {
+    let nowSeconds;
+    try {
+      const resp = await fetch(TIME_API);
+      const data = await resp.json();
+      nowSeconds = Math.floor(new Date(data.dateTime + 'Z').getTime() / 1000);
+    } catch (e) {
+      nowSeconds = Math.floor(Date.now() / 1000);
+    }

+    const countdown = document.getElementById('countdown');
+    if (!expiry || expiry <= 0) {
+      countdown.textContent = 'Restrictions are active.';
+      return;
+    }

+    const diffSecs = expiry - nowSeconds;
+    if (diffSecs <= 0) {
+      countdown.innerHTML = 'Restrictions have <strong>expired</strong>. You can now update God\'s Eye settings.';
+      return;
+    }

+    const days = Math.floor(diffSecs / 86400);
+    const hours = Math.floor((diffSecs % 86400) / 3600);
+    const mins = Math.floor((diffSecs % 3600) / 60);

+    let timeStr = '';
+    if (days > 0) timeStr += `${days} day${days !== 1 ? 's' : ''} `;
+    if (hours > 0) timeStr += `${hours} hr${hours !== 1 ? 's' : ''} `;
+    if (mins > 0 || (!days && !hours)) timeStr += `${mins} min`;

+    countdown.innerHTML = `Time remaining: <strong>${timeStr.trim()}</strong>`;
+  }

+  updateCountdown();
+})();
+</script>
+</body>
+</html>
