+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/gods_eye/gods_eye_navigation_throttle.h"
+
+#include "base/strings/string_util.h"
+#include "base/time/time.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "components/helium_services/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/browser_context.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/web_contents.h"
+#include "net/base/escape.h"
+#include "url/gurl.h"
+
+// static
+std::unique_ptr<GodsEyeNavigationThrottle>
+GodsEyeNavigationThrottle::MaybeCreateThrottleFor(
+    content::NavigationHandle* handle) {
+  // Only throttle main frame navigations
+  if (!handle->IsInMainFrame()) {
+    return nullptr;
+  }
+  // Don't throttle navigations to our own special pages
+  const GURL& url = handle->GetURL();
+  if (url.SchemeIs("chrome") &&
+      (url.host() == chrome::kHeliumRestrictedPageHost ||
+       url.host() == chrome::kHeliumGodsEyeHost)) {
+    return nullptr;
+  }
+
+  content::WebContents* web_contents = handle->GetWebContents();
+  if (!web_contents) return nullptr;
+
+  Profile* profile =
+      Profile::FromBrowserContext(web_contents->GetBrowserContext());
+  if (!profile || profile->IsOffTheRecord()) return nullptr;
+
+  PrefService* prefs = profile->GetPrefs();
+  if (!prefs->GetBoolean(prefs::kGodsEyeActive)) return nullptr;
+
+  return std::make_unique<GodsEyeNavigationThrottle>(handle, prefs);
+}
+
+GodsEyeNavigationThrottle::GodsEyeNavigationThrottle(
+    content::NavigationHandle* handle,
+    PrefService* prefs)
+    : content::NavigationThrottle(handle), pref_service_(prefs) {}
+
+GodsEyeNavigationThrottle::~GodsEyeNavigationThrottle() = default;
+
+const char* GodsEyeNavigationThrottle::GetNameForLogging() {
+  return "GodsEyeNavigationThrottle";
+}
+
+GodsEyeNavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::WillStartRequest() {
+  return CheckNavigation();
+}
+
+GodsEyeNavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::WillRedirectRequest() {
+  return CheckNavigation();
+}
+
+bool GodsEyeNavigationThrottle::IsGodsEyeActive() const {
+  if (!pref_service_->GetBoolean(prefs::kGodsEyeActive)) return false;
+
+  double expiry = pref_service_->GetDouble(prefs::kGodsEyeExpiryTimestamp);
+  if (expiry <= 0.0) return false;
+
+  // Use system clock as authoritative check in the throttle.
+  // TimeAPI is used only in the UI layer; here we trust system time
+  // since this runs in the browser process and cannot be spoofed via JS.
+  double now = base::Time::Now().InSecondsFSinceUnixEpoch();
+  if (now >= expiry) {
+    // Expiry passed — clear the active flag
+    pref_service_->SetBoolean(prefs::kGodsEyeActive, false);
+    return false;
+  }
+  return true;
+}
+
+std::string GodsEyeNavigationThrottle::MatchesDomain(const GURL& url) const {
+  if (!url.has_host()) return "";
+  std::string host = url.host();
+  // Normalize: strip leading "www."
+  if (base::StartsWith(host, "www.", base::CompareCase::INSENSITIVE_ASCII)) {
+    host = host.substr(4);
+  }
+
+  const base::Value::List& domains =
+      pref_service_->GetList(prefs::kGodsEyeBlockedDomains);
+
+  for (const auto& entry : domains) {
+    if (!entry.is_string()) continue;
+    std::string blocked = entry.GetString();
+    // Normalize blocked entry too
+    if (base::StartsWith(blocked, "www.",
+                         base::CompareCase::INSENSITIVE_ASCII)) {
+      blocked = blocked.substr(4);
+    }
+    // Exact match or subdomain match:
+    // host == "sub.example.com" matches blocked "example.com"
+    // host == "example.com" matches blocked "example.com"
+    if (base::EqualsCaseInsensitiveASCII(host, blocked)) {
+      return blocked;
+    }
+    std::string suffix = "." + blocked;
+    if (base::EndsWith(host, suffix,
+                       base::CompareCase::INSENSITIVE_ASCII)) {
+      return blocked;
+    }
+  }
+  return "";
+}
+
+std::string GodsEyeNavigationThrottle::MatchesKeyword(const GURL& url) const {
+  // Check the full URL spec (lowercased) for keyword presence.
+  // This covers: path, query string, and hostname — sufficient for
+  // search queries (e.g. google.com/search?q=blocked_keyword).
+  std::string url_lower = base::ToLowerASCII(url.spec());
+
+  const base::Value::List& keywords =
+      pref_service_->GetList(prefs::kGodsEyeBlockedKeywords);

+  for (const auto& entry : keywords) {
+    if (!entry.is_string()) continue;
+    std::string kw = base::ToLowerASCII(entry.GetString());
+    if (kw.empty()) continue;
+    if (url_lower.find(kw) != std::string::npos) {
+      return entry.GetString();
+    }
+  }
+  return "";
+}
+
+GodsEyeNavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::RedirectToRestrictedPage(
+    const std::string& reason,
+    const std::string& value) {
+  double expiry = pref_service_->GetDouble(prefs::kGodsEyeExpiryTimestamp);
+  std::string redirect_url =
+      std::string(chrome::kHeliumRestrictedPageURL) + "/?reason=" +
+      net::EscapeQueryParamValue(reason, /*use_plus=*/false) + "&value=" +
+      net::EscapeQueryParamValue(value, /*use_plus=*/false) + "&expiry=" +
+      base::NumberToString(static_cast<int64_t>(expiry));

+  navigation_handle()->GetWebContents()->GetController().LoadURL(
+      GURL(redirect_url), content::Referrer(),
+      ui::PAGE_TRANSITION_AUTO_TOPLEVEL, std::string());

+  return CANCEL;
+}
+
+GodsEyeNavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::CheckNavigation() {
+  if (!IsGodsEyeActive()) return PROCEED;

+  const GURL& url = navigation_handle()->GetURL();

+  // 1. Check domain list
+  std::string matched_domain = MatchesDomain(url);
+  if (!matched_domain.empty()) {
+    return RedirectToRestrictedPage("domain", matched_domain);
+  }

+  // 2. Check keyword list against full URL
+  std::string matched_keyword = MatchesKeyword(url);
+  if (!matched_keyword.empty()) {
+    return RedirectToRestrictedPage("keyword", matched_keyword);
+  }

+  return PROCEED;
+}
